<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GoTourNTravels" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/maroon_dark</item>
        <item name="android:windowBackground">@color/ink</item>
    </style>

    <style name="Theme.GoTourNTravels.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/maroon_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/Theme.GoTourNTravels</item>
    </style>
</resources>
