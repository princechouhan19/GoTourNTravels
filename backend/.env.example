# ============ Go Tour N Travels Backend Environment ============
# Copy this file to .env and fill in real values before running.

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:8080

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/gotourntravels

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Razorpay (test mode keys from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder
RAZORPAY_WEBHOOK_SECRET=placeholder

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# Google Maps / Places (used by backend for geocoding fallback)
GOOGLE_MAPS_API_KEY=placeholder

# Firebase Admin (service account JSON path for FCM push)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# OTP settings (mock — OTPs are logged to console in dev)
OTP_LENGTH=6
OTP_TTL_MINUTES=10

# Business
BUSINESS_NAME=Go Tour N Travels
BUSINESS_PHONE=+919000000000
BUSINESS_EMAIL=hello@gotourntravels.com
BUSINESS_ADDRESS=Mount Abu, Rajasthan, India
SOS_EMERGENCY_PHONE=112
